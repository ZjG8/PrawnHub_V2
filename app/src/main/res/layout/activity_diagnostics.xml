<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_soft"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/backButton"
            style="@style/ShrimpHubButton.Nav"
            android:layout_width="112dp"
            android:layout_height="48dp"
            android:text="Back" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="System Diagnostics"
            android:textColor="@color/text_primary"
            android:textSize="26sp"
            android:textStyle="bold" />

        <TextView android:id="@+id/esp32Status" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:background="@drawable/card_background" android:text="ESP32 status..." android:textColor="@color/text_primary" />
        <TextView android:id="@+id/firebaseStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/card_background" android:text="Firebase status..." android:textColor="@color/text_primary" />
        <TextView android:id="@+id/sensorStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/card_background" android:text="Sensor status..." android:textColor="@color/text_primary" />
        <TextView android:id="@+id/syncStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/card_background" android:text="Sync status..." android:textColor="@color/text_primary" />
        <TextView android:id="@+id/lastUpdateStatus" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="10dp" android:background="@drawable/card_background" android:text="Last update..." android:textColor="@color/text_primary" />
    </LinearLayout>
</ScrollView>
