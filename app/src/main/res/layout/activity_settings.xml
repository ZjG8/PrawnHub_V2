<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_soft"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/backButton"
                    style="@style/ShrimpHubButton.Nav"
                    android:layout_width="96dp"
                    android:layout_height="52dp"
                    android:contentDescription="Back"
                    android:text="Back" />

                <TextView
                    android:id="@+id/settingsTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:text="Settings"
                    android:textColor="@color/text_primary"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:contentDescription="PrawnHub logo"
                    android:src="@drawable/prawnhub_logo" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/card_background"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Role"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/accountEmailText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Farmer"
                    android:textColor="@color/text_secondary"
                    android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_background"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Pond Settings"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    style="@style/ShrimpHubFieldLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Temperature" />

                <com.google.android.material.slider.RangeSlider
                    android:id="@+id/temperatureRangeSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:contentDescription="Temperature threshold range"
                    app:labelBehavior="gone" />

                <TextView
                    android:id="@+id/temperatureRangeValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Min: 28.0 C                    Max: 32.0 C"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    style="@style/ShrimpHubFieldLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Salinity" />

                <com.google.android.material.slider.RangeSlider
                    android:id="@+id/salinityRangeSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:contentDescription="Salinity threshold range"
                    app:labelBehavior="gone" />

                <TextView
                    android:id="@+id/salinityRangeValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Min: 15 ppt                    Max: 25 ppt"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <TextView
                    style="@style/ShrimpHubFieldLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Turbidity" />

                <TextView
                    android:id="@+id/turbidityLimitValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Min: 0 NTU        Max: 45 NTU"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.slider.RangeSlider
                    android:id="@+id/turbidityLimitSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:contentDescription="Turbidity threshold range"
                    app:labelBehavior="gone" />

                <TextView
                    style="@style/ShrimpHubFieldLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Overflow Limit" />

                <TextView
                    android:id="@+id/overflowLimitValue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Current: 5 ft"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <com.google.android.material.slider.Slider
                    android:id="@+id/overflowLimitSlider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:contentDescription="Overflow threshold"
                    app:labelBehavior="gone" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_background"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Feeding Automation"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView style="@style/ShrimpHubFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="Feed Time" />
                <EditText android:id="@+id/feedTimeInput" style="@style/ShrimpHubInput" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="6dp" android:focusable="false" android:hint="Feed Time" android:inputType="none" />

                <TextView style="@style/ShrimpHubFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Feeding Interval" />
                <EditText android:id="@+id/feedIntervalInput" style="@style/ShrimpHubInput" android:layout_width="match_parent" android:layout_height="56dp" android:layout_marginTop="6dp" android:hint="Feeding Interval" android:inputType="number" />

                <Switch android:id="@+id/midnightFeedSwitch" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="10dp" android:text="Auto Feed" android:textColor="@color/text_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_background"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Notifications"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <Switch android:id="@+id/soundSwitch" android:layout_width="match_parent" android:layout_height="52dp" android:layout_marginTop="10dp" android:text="Sound alert" android:textColor="@color/text_primary" />
                <Switch android:id="@+id/vibrateSwitch" android:layout_width="match_parent" android:layout_height="52dp" android:text="Vibrate" android:textColor="@color/text_primary" />
                <Switch android:id="@+id/pushSwitch" android:layout_width="match_parent" android:layout_height="52dp" android:text="Push notifications" android:textColor="@color/text_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_background"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Appearance"
                    android:textColor="@color/text_primary"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    style="@style/ShrimpHubFieldLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:text="Theme" />

                <RadioGroup
                    android:id="@+id/themeRadioGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:orientation="vertical">

                    <RadioButton
                        android:id="@+id/themeLightRadio"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Light Mode"
                        android:textColor="@color/text_primary" />

                    <RadioButton
                        android:id="@+id/themeDarkRadio"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:text="Dark Mode"
                        android:textColor="@color/text_primary" />

                    <RadioButton
                        android:id="@+id/themeSystemRadio"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:checked="true"
                        android:text="Follow System"
                        android:textColor="@color/text_primary" />
                </RadioGroup>
            </LinearLayout>

            <Button
                android:id="@+id/aboutButton"
                style="@style/ShrimpHubButton.Secondary"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="14dp"
                android:text="About PrawnHub" />

            <Button
                android:id="@+id/saveSettingsButton"
                style="@style/ShrimpHubButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="18dp"
                android:text="Save Settings" />

            <Button
                android:id="@+id/logoutButton"
                style="@style/ShrimpHubButton.Secondary"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="10dp"
                android:text="Logout" />
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNavContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <include layout="@layout/bottom_nav" />
    </LinearLayout>
</LinearLayout>
