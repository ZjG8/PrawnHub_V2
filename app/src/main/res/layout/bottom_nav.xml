<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:background="@drawable/nav_background"
    android:gravity="center"
    android:orientation="horizontal"
    android:paddingLeft="8dp"
    android:paddingTop="8dp"
    android:paddingRight="8dp"
    android:paddingBottom="10dp">

    <Button android:id="@+id/navDashboard" style="@style/ShrimpHubButton.Nav" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:text="Dashboard" android:textSize="12sp" />
    <Button android:id="@+id/navHistory" style="@style/ShrimpHubButton.Nav" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:text="History" android:textSize="12sp" />
    <Button android:id="@+id/navGrowth" style="@style/ShrimpHubButton.Nav" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:text="Growth" android:textSize="12sp" />
    <Button android:id="@+id/navSettings" style="@style/ShrimpHubButton.Nav" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:text="Settings" android:textSize="12sp" />
</LinearLayout>
