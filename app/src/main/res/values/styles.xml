<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ShrimpHubButton" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:minHeight">52dp</item>
        <item name="backgroundTint">@color/brand_primary</item>
    </style>

    <style name="ShrimpHubButton.Secondary" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="strokeColor">@color/surface_line</item>
        <item name="android:textColor">@color/brand_primary_dark</item>
    </style>

    <style name="ShrimpHubButton.Nav" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="backgroundTint">@color/surface_card</item>
    </style>

    <style name="ShrimpHubInput">
        <item name="android:background">@drawable/input_background</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textColorHint">@color/text_secondary</item>
    </style>
</resources>
