<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_soft"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <Button
                android:id="@+id/backButton"
                style="@style/ShrimpHubButton.Nav"
                android:layout_width="112dp"
                android:layout_height="48dp"
                android:text="Back" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="History"
                android:textColor="@color/text_primary"
                android:textSize="28sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:background="@drawable/card_background"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Date &amp; Time Range"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    style="@style/ShrimpHubFieldLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="Start Date &amp; Time" />

                <Button
                    android:id="@+id/startDateButton"
                    style="@style/ShrimpHubButton.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:text="yyyy-MM-dd HH:mm" />

                <TextView
                    style="@style/ShrimpHubFieldLabel"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="End Date &amp; Time" />

                <Button
                    android:id="@+id/endDateButton"
                    style="@style/ShrimpHubButton.Secondary"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="6dp"
                    android:text="yyyy-MM-dd HH:mm" />

                <Button
                    android:id="@+id/applyDateFilterButton"
                    style="@style/ShrimpHubButton"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="10dp"
                    android:text="Apply Filter" />
            </LinearLayout>

            <Spinner
                android:id="@+id/sensorFilterSpinner"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/dropdown_background"
                android:paddingLeft="16dp"
                android:paddingRight="40dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Graph Analytics"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView android:id="@+id/temperatureChartLabel" style="@style/ShrimpHubFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="Temperature Trend" />
            <com.github.mikephil.charting.charts.LineChart android:id="@+id/temperatureChart" android:layout_width="match_parent" android:layout_height="180dp" android:layout_marginTop="8dp" android:background="@drawable/card_background" />

            <TextView android:id="@+id/salinityChartLabel" style="@style/ShrimpHubFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="Salinity Trend" />
            <com.github.mikephil.charting.charts.LineChart android:id="@+id/salinityChart" android:layout_width="match_parent" android:layout_height="180dp" android:layout_marginTop="8dp" android:background="@drawable/card_background" />

            <TextView android:id="@+id/turbidityChartLabel" style="@style/ShrimpHubFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="Turbidity Trend" />
            <com.github.mikephil.charting.charts.LineChart android:id="@+id/turbidityChart" android:layout_width="match_parent" android:layout_height="180dp" android:layout_marginTop="8dp" android:background="@drawable/card_background" />

            <TextView android:id="@+id/waterLevelChartLabel" style="@style/ShrimpHubFieldLabel" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="14dp" android:text="Water Level Trend" />
            <com.github.mikephil.charting.charts.LineChart android:id="@+id/waterLevelChart" android:layout_width="match_parent" android:layout_height="180dp" android:layout_marginTop="8dp" android:background="@drawable/card_background" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="History List"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/historyEmptyText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/card_background"
                android:padding="12dp"
                android:text="No records found for selected range."
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/historyRecycler"
                android:layout_width="match_parent"
                android:layout_height="420dp"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Firebase Verification"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/card_background"
                android:orientation="vertical"
                android:padding="12dp">

                <TextView
                    android:id="@+id/verificationTimestampText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Latest timestamp: --"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/verificationTemperatureText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Temperature: --"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/verificationSalinityText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="TDS: --"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/verificationTurbidityText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Turbidity: --"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/verificationWaterLevelText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Water Level: --"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <include layout="@layout/bottom_nav" />
</LinearLayout>
