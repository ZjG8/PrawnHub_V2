<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_soft"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="24dp">

        <Button
            android:id="@+id/backButton"
            style="@style/ShrimpHubButton.Nav"
            android:layout_width="112dp"
            android:layout_height="48dp"
            android:layout_gravity="start"
            android:text="Back" />

        <ImageView
            android:layout_width="104dp"
            android:layout_height="104dp"
            android:layout_marginTop="18dp"
            android:contentDescription="PrawnHub logo"
            android:src="@drawable/prawnhub_logo" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="PrawnHub"
            android:textColor="@color/brand_primary_dark"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:gravity="center"
            android:text="Version 1.0"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/card_background"
            android:text="Smart Monitoring and Control System for Indoor Prawn Farming"
            android:textColor="@color/text_primary"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_background"
            android:text="Developed By\nZj Gilbuena\nMikko Garduna\nJovin Barretto\nFranz Velasco\n\nSchool\nPolytechnic University of the Philippines Lopez, Quezon Branch"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/card_background"
            android:text="Technologies Used\n- ESP32\n- Firebase\n- Android Studio"
            android:textColor="@color/text_primary"
            android:textSize="16sp" />

        <Button
            android:id="@+id/contactTeamButton"
            style="@style/ShrimpHubButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="22dp"
            android:text="Contact Team" />
    </LinearLayout>
</ScrollView>
