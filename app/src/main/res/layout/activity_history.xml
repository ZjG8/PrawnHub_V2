<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_soft"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="History"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:scrollbars="none">

            <RadioGroup
                android:id="@+id/filterGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <RadioButton android:id="@+id/filterTemp" android:layout_width="wrap_content" android:layout_height="48dp" android:background="@drawable/chip_selected" android:button="@null" android:checked="true" android:paddingLeft="18dp" android:paddingRight="18dp" android:text="Temperature" android:textColor="@color/text_primary" />
                <RadioButton android:id="@+id/filterSalinity" android:layout_width="wrap_content" android:layout_height="48dp" android:layout_marginLeft="8dp" android:background="@drawable/card_background" android:button="@null" android:paddingLeft="18dp" android:paddingRight="18dp" android:text="Salinity" android:textColor="@color/text_primary" />
                <RadioButton android:id="@+id/filterTurbidity" android:layout_width="wrap_content" android:layout_height="48dp" android:layout_marginLeft="8dp" android:background="@drawable/card_background" android:button="@null" android:paddingLeft="18dp" android:paddingRight="18dp" android:text="Turbidity" android:textColor="@color/text_primary" />
                <RadioButton android:id="@+id/filterWater" android:layout_width="wrap_content" android:layout_height="48dp" android:layout_marginLeft="8dp" android:background="@drawable/card_background" android:button="@null" android:paddingLeft="18dp" android:paddingRight="18dp" android:text="Water Level" android:textColor="@color/text_primary" />
            </RadioGroup>
        </HorizontalScrollView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Today"
            android:textColor="@color/text_primary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/historyChart"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/card_background" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/historyRecycler"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1" />
    </LinearLayout>

    <include layout="@layout/bottom_nav" />
</LinearLayout>
